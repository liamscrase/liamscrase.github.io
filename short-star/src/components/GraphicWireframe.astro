---
// GraphicWireframe.astro — Dark mode UI skeleton / wireframe
---

<div class="gw-wrap" aria-hidden="true">
  <svg class="gw-svg" viewBox="0 0 400 260" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <rect id="shimmer"/>
    </defs>

    <!-- Browser chrome -->
    <rect x="40" y="20" width="320" height="220" rx="6" fill="#0d0d0d" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
    <!-- Title bar -->
    <rect x="40" y="20" width="320" height="28" rx="6" fill="#161616"/>
    <rect x="40" y="34" width="320" height="14" fill="#161616"/>
    <!-- Traffic lights -->
    <circle cx="58" cy="34" r="4" fill="rgba(255,255,255,0.12)"/>
    <circle cx="72" cy="34" r="4" fill="rgba(255,255,255,0.12)"/>
    <circle cx="86" cy="34" r="4" fill="rgba(255,255,255,0.12)"/>
    <!-- URL bar -->
    <rect x="110" y="27" width="180" height="14" rx="3" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>

    <!-- Nav bar -->
    <rect x="40" y="48" width="320" height="24" fill="#111"/>
    <rect x="52"  y="55" width="28" height="9" rx="2" fill="rgba(255,255,255,0.18)"/>
    <rect x="88"  y="57" width="22" height="6" rx="2" fill="rgba(255,255,255,0.08)"/>
    <rect x="118" y="57" width="22" height="6" rx="2" fill="rgba(255,255,255,0.08)"/>
    <rect x="148" y="57" width="22" height="6" rx="2" fill="rgba(255,255,255,0.08)"/>
    <rect x="318" y="54" width="32" height="11" rx="3" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>

    <!-- Hero block -->
    <rect x="52" y="82" width="200" height="12" rx="2" fill="rgba(255,255,255,0.2)"/>
    <rect x="52" y="100" width="160" height="8" rx="2" fill="rgba(255,255,255,0.08)"/>
    <rect x="52" y="113" width="140" height="8" rx="2" fill="rgba(255,255,255,0.08)"/>
    <rect x="52" y="130" width="64" height="20" rx="4" fill="rgba(255,255,255,0.12)" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>

    <!-- Image placeholder -->
    <rect x="262" y="78" width="88" height="82" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
    <line x1="262" y1="78" x2="350" y2="160" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>
    <line x1="350" y1="78" x2="262" y2="160" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>

    <!-- Card row -->
    <rect x="52"  y="174" width="84" height="54" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
    <rect x="60"  y="182" width="40" height="5" rx="1" fill="rgba(255,255,255,0.15)"/>
    <rect x="60"  y="192" width="60" height="4" rx="1" fill="rgba(255,255,255,0.07)"/>
    <rect x="60"  y="200" width="52" height="4" rx="1" fill="rgba(255,255,255,0.07)"/>
    <rect x="60"  y="213" width="28" height="8"  rx="2" fill="rgba(255,255,255,0.1)"/>

    <rect x="146" y="174" width="84" height="54" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
    <rect x="154" y="182" width="40" height="5" rx="1" fill="rgba(255,255,255,0.15)"/>
    <rect x="154" y="192" width="60" height="4" rx="1" fill="rgba(255,255,255,0.07)"/>
    <rect x="154" y="200" width="52" height="4" rx="1" fill="rgba(255,255,255,0.07)"/>
    <rect x="154" y="213" width="28" height="8"  rx="2" fill="rgba(255,255,255,0.1)"/>

    <rect x="240" y="174" width="110" height="54" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
    <rect x="248" y="182" width="40" height="5" rx="1" fill="rgba(255,255,255,0.15)"/>
    <rect x="248" y="192" width="80" height="4" rx="1" fill="rgba(255,255,255,0.07)"/>
    <rect x="248" y="200" width="70" height="4" rx="1" fill="rgba(255,255,255,0.07)"/>
    <rect x="248" y="213" width="28" height="8"  rx="2" fill="rgba(255,255,255,0.1)"/>
  </svg>
</div>

<style>
  .gw-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gw-svg {
    width: 100%;
    height: 100%;
  }
</style>
