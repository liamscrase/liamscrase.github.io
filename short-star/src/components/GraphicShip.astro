---
// GraphicShip.astro — Terminal window with deploy log
---

<div class="frame scale-target">
  <div class="canvas">

    <div class="terminal">

      <div class="titlebar">
        <div class="dots">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
        </div>
        <div class="title">zsh — deploy</div>
      </div>

      <div class="body">
        <div class="line"><span class="green">➜ </span><span class="blue">~/project </span><span class="muted">git push origin main</span></div>
        <div class="line dim">Enumerating objects: 24, done.</div>
        <div class="line dim">Counting objects: 100% (24/24), done.</div>
        <div class="line dim">Writing objects: 100% (13/13), 4.21 KiB</div>
        <div class="line"><span class="dimmer">remote: </span><span class="dim">Resolving deltas: 100% (8/8)</span></div>
        <div class="divider"></div>
        <div class="line"><span class="dimmer">▸ </span><span class="purple">Vercel </span><span class="dim">triggered deployment...</span></div>
        <div class="line dim">Installing dependencies</div>
        <div class="progress-wrap">
          <div class="progress-track">
            <div class="progress-bar"></div>
          </div>
        </div>
        <div class="line dim">Building application...</div>
        <div class="line dim">Running checks</div>
        <div class="line"><span class="dim">Performance score: </span><span class="green">98</span><span class="dim"> / 100</span></div>
        <div class="divider"></div>
        <div class="line"><span class="green">✓ </span><span class="teal">Deployed to production</span><span class="dimmer"> · 12s</span></div>
        <div class="line"><span class="green">➜ </span><span class="blue">~/project </span><span class="cursor"></span></div>
      </div>

    </div>

  </div>
</div>

<style>
  .frame {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .canvas {
    position: absolute;
    top: 0; left: 0;
    width: 400px;
    height: 225px;
    transform-origin: top left;
  }

  /* ── Terminal shell ── */
  .terminal {
    width: 400px;
    height: 225px;
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  /* ── Title bar ── */
  .titlebar {
    position: relative;
    height: 26px;
    background: #1a1a1a;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 10px;
    flex-shrink: 0;
  }

  .dots { display: flex; gap: 4px; }

  .dot { width: 7px; height: 7px; border-radius: 50%;   background: rgba(255,255,255,0.15);
  }
  .title {
    position: absolute;
    left: 0; right: 0;
    text-align: center;
    font-family: monospace;
    font-size: 7px;
    color: rgba(255,255,255,0.2);
    pointer-events: none;
  }

  /* ── Body ── */
  .body {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 8px 12px;
    overflow: hidden;
  }

  .line {
    font-family: monospace;
    font-size: 7.5px;
    line-height: 1.7;
    white-space: nowrap;
  }

  .divider {
    height: 1px;
    background: rgba(255,255,255,0.06);
    margin: 1px 0;
    flex-shrink: 0;
  }

  /* ── Progress bar ── */
  .progress-wrap { padding: 2px 0; }

  .progress-track {
    height: 5px;
    background: rgba(255,255,255,0.06);
    border-radius: 99px;
    overflow: hidden;
  }

  .progress-bar {
    height: 100%;
    width: 0;
    background: #3cd870;
    border-radius: 99px;
    opacity: 0.85;
    animation: fill 2s ease-out 0.5s forwards;
  }

  @keyframes fill {
    from { width: 0; }
    to   { width: 100%; }
  }

  /* ── Syntax colors ── */
  .dim    { color: rgba(255,255,255,0.35); }
  .dimmer { color: rgba(255,255,255,0.18); }
  .muted  { color: rgba(255,255,255,0.65); }
  .green  { color: #3cd870; }
  .teal   { color: #3cd8b0; }
  .blue   { color: #4b95ea; }
  .purple { color: #7b7bea; }

  /* ── Blinking cursor ── */
  .cursor {
    display: inline-block;
    width: 1.5px;
    height: 9px;
    background: rgba(255,255,255,0.7);
    vertical-align: middle;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<script is:inline>
  (() => {
    function scale(frame) {
      const canvas = frame.querySelector('.canvas');
      if (!canvas) return;
      const s = Math.min(frame.clientWidth / 400, frame.clientHeight / 225);
      canvas.style.transform = `scale(${s})`;
      canvas.style.left = `${(frame.clientWidth  - 400 * s) / 2}px`;
      canvas.style.top  = `${(frame.clientHeight - 225 * s) / 2}px`;
    }
    const ro = new ResizeObserver(entries => entries.forEach(e => scale(e.target)));
    document.querySelectorAll('.scale-target').forEach(f => { scale(f); ro.observe(f); });
  })();
</script>