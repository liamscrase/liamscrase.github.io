---
// GraphicResearch.astro — Brainstorm mind map with scattered idea nodes
---

<div class="gr-wrap" aria-hidden="true">
  <svg class="gr-svg" viewBox="0 0 400 260" xmlns="http://www.w3.org/2000/svg">

    <!-- Faint connector lines — hand-drawn feel, slightly irregular -->
    <g stroke="rgba(255,255,255,0.07)" stroke-width="1" fill="none">
      <line x1="200" y1="130" x2="108" y2="72"/>
      <line x1="200" y1="130" x2="290" y2="68"/>
      <line x1="200" y1="130" x2="316" y2="155"/>
      <line x1="200" y1="130" x2="258" y2="208"/>
      <line x1="200" y1="130" x2="130" y2="210"/>
      <line x1="200" y1="130" x2="72"  y2="148"/>
      <line x1="200" y1="130" x2="168" y2="44"/>
      <line x1="200" y1="130" x2="338" y2="98"/>
      <!-- Second level -->
      <line x1="108" y1="72"  x2="62"  y2="42"/>
      <line x1="108" y1="72"  x2="148" y2="30"/>
      <line x1="290" y1="68"  x2="338" y2="38"/>
      <line x1="316" y1="155" x2="368" y2="178"/>
      <line x1="258" y1="208" x2="304" y2="240"/>
      <line x1="130" y1="210" x2="80"  y2="238"/>
      <line x1="72"  y1="148" x2="32"  y2="118"/>
      <line x1="72"  y1="148" x2="38"  y2="178"/>
    </g>

    <!-- Second-level nodes — tiny dots -->
    <g fill="#1a1a1a" stroke="rgba(255,255,255,0.12)" stroke-width="1">
      <circle cx="62"  cy="42"  r="16"/>
      <circle cx="148" cy="30"  r="16"/>
      <circle cx="338" cy="38"  r="16"/>
      <circle cx="368" cy="178" r="14"/>
      <circle cx="304" cy="240" r="14"/>
      <circle cx="80"  cy="238" r="14"/>
      <circle cx="32"  cy="118" r="13"/>
      <circle cx="38"  cy="178" r="13"/>
    </g>

    <!-- Second-level labels -->
    <g fill="rgba(255,255,255,0.28)" font-size="7" font-family="monospace" text-anchor="middle">
      <text x="62"  y="44">SURVEY</text>
      <text x="148" y="32">EMPATHY</text>
      <text x="338" y="40">SWOT</text>
      <text x="368" y="181">GAPS</text>
      <text x="304" y="243">FUNNEL</text>
      <text x="80"  y="241">PERSONA</text>
      <text x="32"  y="120">PAIN</text>
      <text x="38"  y="180">GOALS</text>
    </g>

    <!-- Primary nodes -->
    <g fill="#111" stroke-width="1">
      <circle cx="108" cy="72"  r="26" stroke="#4b95ea" stroke-opacity="0.5"/>
      <circle cx="290" cy="68"  r="26" stroke="#7b7bea" stroke-opacity="0.5"/>
      <circle cx="316" cy="155" r="24" stroke="#4b95ea" stroke-opacity="0.4"/>
      <circle cx="258" cy="208" r="24" stroke="#7b7bea" stroke-opacity="0.4"/>
      <circle cx="130" cy="210" r="24" stroke="#4b95ea" stroke-opacity="0.4"/>
      <circle cx="72"  cy="148" r="22" stroke="#7b7bea" stroke-opacity="0.35"/>
      <circle cx="168" cy="44"  r="22" stroke="#4b95ea" stroke-opacity="0.35"/>
      <circle cx="338" cy="98"  r="20" stroke="#7b7bea" stroke-opacity="0.3"/>
    </g>

    <!-- Primary labels -->
    <g font-family="monospace" text-anchor="middle">
      <text x="108" y="69"  fill="rgba(255,255,255,0.7)" font-size="8">USER</text>
      <text x="108" y="79"  fill="rgba(255,255,255,0.7)" font-size="8">RESEARCH</text>
      <text x="290" y="65"  fill="rgba(255,255,255,0.7)" font-size="8">COMPETITOR</text>
      <text x="290" y="75"  fill="rgba(255,255,255,0.7)" font-size="8">ANALYSIS</text>
      <text x="316" y="152" fill="rgba(255,255,255,0.65)" font-size="8">USER</text>
      <text x="316" y="162" fill="rgba(255,255,255,0.65)" font-size="8">FLOWS</text>
      <text x="258" y="205" fill="rgba(255,255,255,0.65)" font-size="8">METRICS</text>
      <text x="258" y="215" fill="rgba(255,255,255,0.65)" font-size="8">&#38; DATA</text>
      <text x="130" y="207" fill="rgba(255,255,255,0.65)" font-size="8">STAKEHOLDER</text>
      <text x="130" y="217" fill="rgba(255,255,255,0.65)" font-size="8">INTERVIEWS</text>
      <text x="72"  y="145" fill="rgba(255,255,255,0.6)" font-size="8">MARKET</text>
      <text x="72"  y="155" fill="rgba(255,255,255,0.6)" font-size="8">SIZE</text>
      <text x="168" y="41"  fill="rgba(255,255,255,0.6)" font-size="8">HEURISTIC</text>
      <text x="168" y="51"  fill="rgba(255,255,255,0.6)" font-size="8">REVIEW</text>
      <text x="338" y="95"  fill="rgba(255,255,255,0.55)" font-size="7.5">TRENDS</text>
      <text x="338" y="104" fill="rgba(255,255,255,0.55)" font-size="7.5">&#38; SIGNALS</text>
    </g>

    <!-- Centre node with pulse -->
    <circle cx="200" cy="130" r="36" fill="none" stroke="#4b95ea" stroke-width="1" opacity="0">
      <animate attributeName="r"       values="24;44;24" dur="3.5s" repeatCount="indefinite"/>
      <animate attributeName="opacity" values="0.3;0;0.3" dur="3.5s" repeatCount="indefinite"/>
    </circle>
    <circle cx="200" cy="130" r="24" fill="#0d1f3c" stroke="#4b95ea" stroke-width="1.5"/>
    <text x="200" y="127" text-anchor="middle" fill="rgba(255,255,255,0.9)" font-size="9" font-family="monospace">PROBLEM</text>
    <text x="200" y="139" text-anchor="middle" fill="rgba(255,255,255,0.9)" font-size="9" font-family="monospace">SPACE</text>

  </svg>
</div>

<style>
  .gr-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gr-svg {
    width: 100%;
    height: 100%;
  }
</style>