---
// GraphicBuild.astro — Code editor with syntax highlighting
---

<div class="frame scale-target">
  <div class="canvas">

    <div class="editor">

      <div class="titlebar">
        <div class="dots">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
        </div>
        <div class="filename">index.astro</div>
      </div>

      <div class="body">
        <div class="line"><span class="ln">1</span><span class="dim">---</span></div>
        <div class="line"><span class="ln">2</span><span class="purple">const</span><span class="dim2">&nbsp;&#123;&nbsp;</span><span class="muted">title,&nbsp;href</span><span class="dim2">&nbsp;&#125;&nbsp;=&nbsp;</span><span class="blue">Astro</span><span class="dim2">.props</span></div>
        <div class="line"><span class="ln">3</span><span class="dim">---</span></div>
        <div class="line"><span class="ln">4</span></div>
        <div class="line"><span class="ln">5</span><span class="dim2">&lt;</span><span class="green">section</span><span class="dim2">&nbsp;</span><span class="violet">class</span><span class="dim2">="</span><span class="teal">card</span><span class="dim2">"&gt;</span></div>
        <div class="line"><span class="ln">6</span><span class="i1"></span><span class="dim2">&lt;</span><span class="green">h2</span><span class="dim2">&gt;</span><span class="muted">&#123;</span><span class="blue">title</span><span class="muted">&#125;</span><span class="dim2">&lt;/</span><span class="green">h2</span><span class="dim2">&gt;</span></div>
        <div class="line"><span class="ln">7</span><span class="i1"></span><span class="dim2">&lt;</span><span class="green">a</span><span class="dim2">&nbsp;</span><span class="violet">href</span><span class="dim2">=&#123;</span><span class="blue">href</span><span class="dim2">&#125;&gt;</span></div>
        <div class="line"><span class="ln">8</span><span class="i2"></span><span class="dim2">&lt;</span><span class="purple">slot </span><span class="dim2">/&gt;</span></div>
        <div class="line"><span class="ln">9</span><span class="i1"></span><span class="dim2">&lt;/</span><span class="green">a</span><span class="dim2">&gt;</span></div>
        <div class="line active"><span class="ln">10</span><span class="dim2">&lt;/</span><span class="green">section</span><span class="dim2">&gt;</span></div>
        <div class="line"><span class="ln">11</span></div>
        <div class="line"><span class="ln">12</span><span class="dim2">&lt;</span><span class="green">style</span><span class="dim2">&gt;</span></div>
        <div class="line"><span class="ln">13</span><span class="violet">.card</span><span class="dim2">&nbsp;&#123;</span><span class="cursor"></span></div>
      </div>

    </div>

  </div>
</div>

<style>
  .frame {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .canvas {
    position: absolute;
    top: 0; left: 0;
    width: 400px;
    height: 225px;
    transform-origin: top left;
  }

  /* ── Editor shell ── */
  .editor {
    width: 400px;
    height: 225px;
    background: #0d0d0d;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  /* ── Title bar ── */
  .titlebar {
    position: relative;
    height: 26px;
    background: #161616;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 10px;
    flex-shrink: 0;
  }

  .dots { display: flex; gap: 4px; }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
  }

  .filename {
    position: absolute;
    left: 0; right: 0;
    text-align: center;
    pointer-events: none;
    font-family: "Chivo Mono", monospace;
    font-size: 7px;
    color: rgba(255,255,255,0.2);
  }

  /* ── Body ── */
  .body {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    padding: 7px 10px 7px 0;
    overflow: hidden;
  }

  /* ── Lines ── */
  .line {
    font-family: "Chivo Mono", monospace;
    font-size: 7.5px;
    line-height: 1.85;
    white-space: nowrap;
    display: flex;
    align-items: center;
  }

  .line.active {
    background: rgba(255,255,255,0.04);
    border-radius: 2px;
    margin: 0 -10px 0 0;
    padding: 0 10px 0 0;
  }

  /* ── Line number ── */
  .ln {
    display: inline-block;
    width: 28px;
    padding-right: 10px;
    text-align: right;
    font-family: "Chivo Mono", monospace;
    font-size: 7px;
    color: rgba(255,255,255,0.16);
    flex-shrink: 0;
    border-right: 1px solid rgba(255,255,255,0.05);
    margin-right: 10px;
  }

  /* ── Indent helpers ── */
  .i1 { display: inline-block; width: 14px; flex-shrink: 0; }
  .i2 { display: inline-block; width: 28px; flex-shrink: 0; }

  /* ── Syntax colors ── */
  .dim    { color: rgba(255,255,255,0.22); }
  .dim2   { color: rgba(255,255,255,0.32); }
  .muted  { color: rgba(255,255,255,0.65); }
  .blue   { color: #4b95ea; }
  .purple { color: #7b7bea; }
  .green  { color: #3cd870; }
  .violet { color: #a45bea; }
  .teal   { color: #3cd8b0; }

  /* ── Blinking cursor ── */
  .cursor {
    display: inline-block;
    width: 1.5px;
    height: 10px;
    background: #4b95ea;
    margin-left: 1px;
    vertical-align: middle;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>