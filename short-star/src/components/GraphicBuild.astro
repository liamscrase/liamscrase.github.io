---
// GraphicBuild.astro — Code editor with syntax highlighting
---

<div class="frame scale-target">
  <div class="canvas">

    <div class="editor">

      <div class="titlebar">
        <div class="dots">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
        </div>
        <div class="filename">Component.astro</div>
      </div>

      <div class="body">

        <div class="gutter">
          <span>1</span><span>2</span><span>3</span>
          <span>4</span><span>5</span><span>6</span>
          <span>7</span><span>8</span><span>9</span>
          <span>10</span><span>11</span><span>12</span>
          <span>13</span>
        </div>

        <div class="code">
          <div class="line"><span class="dim">---</span></div>
          <div class="line"><span class="purple">const </span><span class="muted">&#123; title, href &#125; = </span><span class="blue">Astro</span><span class="dim2">.props</span></div>
          <div class="line"><span class="dim">---</span></div>
          <div class="line">&nbsp;</div>
          <div class="line"><span class="dim2">&lt;</span><span class="green">section </span><span class="violet">class</span><span class="dim2">="</span><span class="teal">card</span><span class="dim2">"&gt;</span></div>
          <div class="line"><span class="indent1"></span><span class="dim2">&lt;</span><span class="green">h2</span><span class="dim2">&gt;</span><span class="muted">&#123;</span><span class="blue">title</span><span class="muted">&#125;</span><span class="dim2">&lt;/</span><span class="green">h2</span><span class="dim2">&gt;</span></div>
          <div class="line"><span class="indent1"></span><span class="dim2">&lt;</span><span class="green">a </span><span class="violet">href</span><span class="dim2">=&#123;</span><span class="blue">href</span><span class="dim2">&#125;&gt;</span></div>
          <div class="line"><span class="indent2"></span><span class="dim2">&lt;</span><span class="purple">slot </span><span class="dim2">/&gt;</span></div>
          <div class="line"><span class="indent1"></span><span class="dim2">&lt;/</span><span class="green">a</span><span class="dim2">&gt;</span></div>
          <div class="line active"><span class="dim2">&lt;/</span><span class="green">section</span><span class="dim2">&gt;</span></div>
          <div class="line">&nbsp;</div>
          <div class="line"><span class="dim2">&lt;</span><span class="green">style</span><span class="dim2">&gt;</span></div>
          <div class="line"><span class="violet">.card </span><span class="dim2">&#123;</span><span class="cursor"></span></div>
        </div>

      </div>
    </div>

  </div>
</div>

<style>
  .frame {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .canvas {
    position: absolute;
    top: 0; left: 0;
    width: 400px;
    height: 225px;
    transform-origin: top left;
  }

  /* ── Editor shell ── */
  .editor {
    width: 400px;
    height: 225px;
    background: #0d0d0d;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  /* ── Title bar ── */
  .titlebar {
    position: relative;
    height: 26px;
    background: #161616;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 10px;
    flex-shrink: 0;
  }

  .dots { display: flex; gap: 4px; }

  .dot { width: 7px; height: 7px; border-radius: 50%;   background: rgba(255,255,255,0.15);
  }
  .filename {
    position: absolute;
    left: 0; right: 0; text-align: center; pointer-events: none;
    font-family: monospace;
    font-size: 7px;
    color: rgba(255,255,255,0.2);
  }

  /* ── Editor body ── */
  .body {
    flex: 1;
    min-height: 0;
    display: flex;
  }

  /* ── Line numbers ── */
  .gutter {
    background: #111;
    border-right: 1px solid rgba(255,255,255,0.05);
    display: flex;
    flex-direction: column;
    padding: 7px 6px 7px 4px;
    flex-shrink: 0;
  }

  .gutter span {
    font-family: monospace;
    font-size: 7px;
    line-height: 1.85;
    color: rgba(255,255,255,0.16);
    text-align: right;
    display: block;
  }

  /* ── Code area ── */
  .code {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 7px 10px;
    overflow: hidden;
  }

  .line {
    font-family: monospace;
    font-size: 7.5px;
    line-height: 1.85;
    white-space: nowrap;
    display: flex;
    align-items: center;
  }

  .line.active {
    background: rgba(255,255,255,0.04);
    border-radius: 2px;
    margin: 0 -10px;
    padding: 0 10px;
  }

  /* ── Indent helpers ── */
  .indent1 { display: inline-block; width: 14px; }
  .indent2 { display: inline-block; width: 28px; }

  /* ── Syntax colors ── */
  .dim    { color: rgba(255,255,255,0.22); }
  .dim2   { color: rgba(255,255,255,0.32); }
  .muted  { color: rgba(255,255,255,0.65); }
  .blue   { color: #4b95ea; }
  .purple { color: #7b7bea; }
  .green  { color: #3cd870; }
  .violet { color: #a45bea; }
  .teal   { color: #3cd8b0; }

  /* ── Blinking cursor ── */
  .cursor {
    display: inline-block;
    width: 1.5px;
    height: 10px;
    background: #4b95ea;
    margin-left: 1px;
    vertical-align: middle;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<script is:inline>
  (() => {
    function scale(frame) {
      const canvas = frame.querySelector('.canvas');
      if (!canvas) return;
      const s = Math.min(frame.clientWidth / 400, frame.clientHeight / 225);
      canvas.style.transform = `scale(${s})`;
      canvas.style.left = `${(frame.clientWidth  - 400 * s) / 2}px`;
      canvas.style.top  = `${(frame.clientHeight - 225 * s) / 2}px`;
    }
    const ro = new ResizeObserver(entries => entries.forEach(e => scale(e.target)));
    document.querySelectorAll('.scale-target').forEach(f => { scale(f); ro.observe(f); });
  })();
</script>