---
import Layout from "../layouts/Layout.astro";
import FadeUpAnimation from "../components/FadeUpAnimation.astro";

const featuredProjects = [
  {
    title: "BuyerScore Website Redesign (In development)",
    year: "2026",
    description:
      "Redesigned the BuyerScore website to improve the user experience and improve brand awareness.",
    href: "https://buyerscore-co-nz-2-temp.azurewebsites.net/",
    image: "/images/buyerscore/buyerscore-home.webp",
    imageAlt: "BuyerScore Website Redesign preview",
    ariaLabel: "View BuyerScore Website Redesign project details",
    buttonText: "Visit staging site",
  },
  {
    title: "Avanti Finance App",
    year: "2025",
    description:
    "A convenient mobile and web app for customers to view where they're at with their loan repayments.",
    href: "https://www.avantifinance.app/",
    image: "/images/avanti-app/avanti-home.webp",
    imageAlt: "Avanti Finance App preview",
    ariaLabel: "View Avanti Finance App project details",
    buttonText: "Find out more",
  },
  {
    title: "White label car dealership template",
    year: "2024",
    description:
      "That latest version of Acme Cars, a car dealership template that forms the basis for many car dealership websites in New Zealand.",
    href: "https://acmecars.co.nz",
    image: "/images/acme5/websites-home.webp",
    imageAlt: "White label website template for car dealerships",
    ariaLabel: "View Acme Website Template project details",
    buttonText: "See demo site",
  },
];

const websiteBuilds = [
  {
    title: "The Serious Sandwich",
    year: "2026",
    description: "Food ordering website that is guaranteed to make you hungry",
    image: "/images/the-serious-sandwich/the-serious-sandwich-home.webp",
    href: "https://theserioussandwich.nz",
    buttonText: "Visit live website",
  },
  {
    title: "Te Rapa Cars",
    year: "2025",
    description: "A car dealership website with a sleek, custom home page and templated interior pages.",
    image: "/images/te-rapa/te-rapa-home.webp",
    href: "https://terapacars.co.nz",
    buttonText: "Visit live website",
  },
  {
    title: "Simply Stunning Studios Tekapo",
    year: "2025",
    description: "Lakeside holiday studios with links to online booking.",
    image: "/images/simply-stunning/simply-stunning-home.webp",
    href: "https://simplystunningstudiostekapo.nz",
    buttonText: "Visit live website",
  },
];
---

<FadeUpAnimation />

<Layout>
  <section id="body-wrapper">
    <section id="banner">
      <div class="content">
        <div class="text">
          <h1>
            Bringing ideas from design to execution.
            <br /><span>(After my coffee, of course)</span>
          </h1>
        </div>
  
        <img
          class="banner-illustration"
          src="/images/liam-cartoon.svg"
          alt=""
          width="200"
          height="200"
        />

      </div>
    </section>
    <div id="main" class="content">
      <div id="case-studies">
        <div class="section-header">
          <h2>Featured Projects</h2>
          <p>Some of my favorite projects that I've worked on.</p>
        </div>
        <div class="project-list">
          {featuredProjects.map((project, index) => (
            <div class={`project-card fade-up${index % 2 === 1 ? " reverse" : ""}`}>
              <img class="project-image" src={project.image} alt={project.imageAlt} />
              <div class="text">
                <h3>{project.title}</h3>
                <span>{project.year}</span>
                <p>{project.description}</p>
                <a target="_blank" class="button grey" href={project.href} aria-label={project.ariaLabel}>
                  {project.buttonText} <i class="icon-arrow"></i>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div id="website-builds">
        <div class="section-header">
          <h2>Website builds</h2>
          <p>Websites designed, built, and launched for real clients.</p>
        </div>
        <div class="website-builds-grid">
          {websiteBuilds.map((site) => (
            <article class="website-builds-card fade-up">
              <img
                src={site.image}
                alt=""
                width="600"
                height="400"
                class="website-builds-card-image"
              />
              <div class="website-builds-card-body">
                <h3>{site.title}</h3>
                <span>{site.year}</span>
                <p>{site.description}</p>
                <a target="_blank" href={site.href} class="button grey">
                  {site.buttonText} <i class="icon-arrow"></i>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
