---
import Layout from "../layouts/Layout.astro";
import FadeUpAnimation from "../components/FadeUpAnimation.astro";
---

<FadeUpAnimation />

<Layout title="BuyerScore">
  <link rel="stylesheet" href="/buyerscore.css" />

  <div id="body-wrapper">
    <article class="case-study content">
      <header class="header">
        <h1 class="title">BuyerScore</h1>
        <hr class="divider" aria-hidden="true" />
      </header>

      <div class="main">
        <div class="info">
          <section class="section">
            <h3 class="section-title">Overview</h3>
            <div class="section-body">
              <p>BuyerScore is a New Zealand platform that helps car buyers find and compare dealerships through verified customer reviews and an annual awards programme.</p>
              <p>The project involved a full redesign of the platform, focusing on improving how trust signals and award recognition are communicated to buyers.</p>
            </div>
          </section>

          <div class="meta">
            <section class="section">
              <h3 class="section-title">My Role</h3>
              <ul class="section-body list">
                <li>UI Design</li>
                <li>Visual Design</li>
                <li>Prototyping</li>
              </ul>
            </section>
            <section class="section">
              <h3 class="section-title">Year</h3>
              <p class="section-body">2026</p>
            </section>
          </div>

          <a
            href="https://www.buyerscore.co.nz/"
            target="_blank"
            rel="noopener noreferrer"
            class="cta"
          >
            Visit live site <i class="icon-arrow"></i>
          </a>
        </div>

        <div class="hero">
          <img
            src="/images/buyerscore/buyerscore_hero.webp"
            alt="BuyerScore website homepage"
          />
        </div>
      </div>

      <section class="comparison">
        <div class="intro">
          <h2>Dealership profile page</h2>
          <p>Discover ratings &amp; reviews for your chosen dealership. See rating subcategories, awards and customer reviews.</p>
        </div>

        <div class="row">
          <div class="col">
            <h3>Previous intro section</h3>
            <ul>
              <li>Decorative hero image added no informational value</li>
              <li>Recommendation rate and award status buried below the fold</li>
              <li>Rating breakdown in a dense table, difficult to scan</li>
            </ul>
            <div class="image">
              <img src="/images/buyerscore/dealership-section/intro-old.webp" alt="Previous intro section" />
            </div>
          </div>
          <span class="arrow" aria-hidden="true"></span>
          <div class="col">
            <h3>Current intro section</h3>
            <ul>
              <li>Key trust signals surfaced in the header</li>
              <li>Recommendation rate promoted to a prominent visual pill</li>
              <li>Rating categories icon-led and easier to scan</li>
            </ul>
            <div class="image">
              <img src="/images/buyerscore/dealership-section/intro-new.webp" alt="Current intro section" />
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col">
            <h3>Previous awards</h3>
            <ul>
              <li>Badges were visually garish and difficult to read</li>
              <li>Fragmented layout</li>
            </ul>
            <div class="image">
              <img src="/images/buyerscore/dealership-section/awards-old.webp" alt="Previous awards" />
            </div>
          </div>
          <span class="arrow" aria-hidden="true"></span>
          <div class="col">
            <h3>Current awards</h3>
            <ul>
              <li>Fresh badge design with more contrast for better legibility</li>
              <li>Cohesive, symmetrical design with highlighted background</li>
            </ul>
            <div class="image">
              <img src="/images/buyerscore/dealership-section/awards-new.webp" alt="Current awards" />
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col">
            <h3>Previous reviews</h3>
            <ul>
              <li>Two basic dropdowns for sorting and filtering</li>
              <li>No way to search for specific topics or keywords</li>
              <li>No indication of how the dealership handles negative feedback</li>
            </ul>
            <div class="image">
              <img src="/images/buyerscore/dealership-section/reviews-old.webp" alt="Previous reviews" />
            </div>
          </div>
          <span class="arrow" aria-hidden="true"></span>
          <div class="col">
            <h3>Current reviews</h3>
            <ul>
              <li>Keyword search lets buyers find relevant reviews quickly</li>
              <li>Star rating filter shows percentage breakdown at a glance</li>
              <li>Response rate shown upfront as an accountability signal</li>
            </ul>
            <div class="image">
              <img src="/images/buyerscore/dealership-section/reviews-new.webp" alt="Current reviews" />
            </div>
          </div>
        </div>
      </section>
    </article>
  </div>
</Layout>
