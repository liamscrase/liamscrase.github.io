---
// GraphicBuild.astro — Code editor with syntax highlighting
---

<div class="gb-wrap" aria-hidden="true">
  <svg class="gb-svg" viewBox="0 0 400 260" xmlns="http://www.w3.org/2000/svg" font-family="monospace" font-size="9.5">

    <!-- Editor window -->
    <rect x="30" y="16" width="340" height="228" rx="6" fill="#0d0d0d" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>

    <!-- Title bar -->
    <rect x="30" y="16" width="340" height="26" rx="6" fill="#161616"/>
    <rect x="30" y="29"  width="340" height="13" fill="#161616"/>
    <circle cx="48" cy="29" r="4" fill="rgba(255,255,255,0.12)"/>
    <circle cx="62" cy="29" r="4" fill="rgba(255,255,255,0.12)"/>
    <circle cx="76" cy="29" r="4" fill="rgba(255,255,255,0.12)"/>
    <text x="200" y="33" text-anchor="middle" fill="rgba(255,255,255,0.2)" font-size="8">Component.astro</text>

    <!-- Gutter -->
    <rect x="30" y="42" width="28" height="202" fill="#111" rx="0"/>

    <!-- Line numbers -->
    <g fill="rgba(255,255,255,0.18)" font-size="8.5">
      <text x="51" y="57"  text-anchor="end">1</text>
      <text x="51" y="71"  text-anchor="end">2</text>
      <text x="51" y="85"  text-anchor="end">3</text>
      <text x="51" y="99"  text-anchor="end">4</text>
      <text x="51" y="113" text-anchor="end">5</text>
      <text x="51" y="127" text-anchor="end">6</text>
      <text x="51" y="141" text-anchor="end">7</text>
      <text x="51" y="155" text-anchor="end">8</text>
      <text x="51" y="169" text-anchor="end">9</text>
      <text x="51" y="183" text-anchor="end">10</text>
      <text x="51" y="197" text-anchor="end">11</text>
      <text x="51" y="211" text-anchor="end">12</text>
      <text x="51" y="225" text-anchor="end">13</text>
    </g>

    <!-- Active line highlight -->
    <rect x="58" y="176" width="304" height="13" fill="rgba(255,255,255,0.04)" rx="1"/>

    <!-- Code lines — syntax coloured -->
    <!-- Line 1: --- -->
    <text x="64" y="57" fill="rgba(255,255,255,0.25)">---</text>

    <!-- Line 2: const { title } = Astro.props -->
    <text x="64" y="71">
      <tspan fill="#7b7bea">const </tspan>
      <tspan fill="rgba(255,255,255,0.7)">&#123; title, href &#125; = </tspan>
      <tspan fill="#4b95ea">Astro</tspan>
      <tspan fill="rgba(255,255,255,0.5)">.props</tspan>
    </text>

    <!-- Line 3: --- -->
    <text x="64" y="85" fill="rgba(255,255,255,0.25)">---</text>

    <!-- Line 4: blank -->

    <!-- Line 5: <section class= -->
    <text x="64" y="113">
      <tspan fill="rgba(255,255,255,0.3)">&lt;</tspan>
      <tspan fill="#3cd870">section</tspan>
      <tspan fill="#a45bea"> class</tspan>
      <tspan fill="rgba(255,255,255,0.5)">=</tspan>
      <tspan fill="#3cd8b0">"card"</tspan>
      <tspan fill="rgba(255,255,255,0.3)">&gt;</tspan>
    </text>

    <!-- Line 6:   <h2>{title}</h2> -->
    <text x="64" y="127">
      <tspan fill="rgba(255,255,255,0.2)">  </tspan>
      <tspan fill="rgba(255,255,255,0.3)">&lt;</tspan>
      <tspan fill="#3cd870">h2</tspan>
      <tspan fill="rgba(255,255,255,0.3)">&gt;</tspan>
      <tspan fill="rgba(255,255,255,0.6)">&#123;</tspan>
      <tspan fill="#4b95ea">title</tspan>
      <tspan fill="rgba(255,255,255,0.6)">&#125;</tspan>
      <tspan fill="rgba(255,255,255,0.3)">&lt;/</tspan>
      <tspan fill="#3cd870">h2</tspan>
      <tspan fill="rgba(255,255,255,0.3)">&gt;</tspan>
    </text>

    <!-- Line 7:   <a href={href}> -->
    <text x="64" y="141">
      <tspan fill="rgba(255,255,255,0.2)">  </tspan>
      <tspan fill="rgba(255,255,255,0.3)">&lt;</tspan>
      <tspan fill="#3cd870">a </tspan>
      <tspan fill="#a45bea">href</tspan>
      <tspan fill="rgba(255,255,255,0.5)">=&#123;</tspan>
      <tspan fill="#4b95ea">href</tspan>
      <tspan fill="rgba(255,255,255,0.5)">&#125;</tspan>
      <tspan fill="rgba(255,255,255,0.3)">&gt;</tspan>
    </text>

    <!-- Line 8:     <slot /> -->
    <text x="64" y="155">
      <tspan fill="rgba(255,255,255,0.2)">    </tspan>
      <tspan fill="rgba(255,255,255,0.3)">&lt;</tspan>
      <tspan fill="#7b7bea">slot </tspan>
      <tspan fill="rgba(255,255,255,0.3)">/&gt;</tspan>
    </text>

    <!-- Line 9:   </a> -->
    <text x="64" y="169">
      <tspan fill="rgba(255,255,255,0.2)">  </tspan>
      <tspan fill="rgba(255,255,255,0.3)">&lt;/</tspan>
      <tspan fill="#3cd870">a</tspan>
      <tspan fill="rgba(255,255,255,0.3)">&gt;</tspan>
    </text>

    <!-- Line 10: </section> — active line -->
    <text x="64" y="183">
      <tspan fill="rgba(255,255,255,0.3)">&lt;/</tspan>
      <tspan fill="#3cd870">section</tspan>
      <tspan fill="rgba(255,255,255,0.3)">&gt;</tspan>
    </text>

    <!-- Line 11: blank -->

    <!-- Line 12: <style> -->
    <text x="64" y="211">
      <tspan fill="rgba(255,255,255,0.3)">&lt;</tspan>
      <tspan fill="#3cd870">style</tspan>
      <tspan fill="rgba(255,255,255,0.3)">&gt;</tspan>
    </text>

    <!-- Line 13: .card { — with blinking cursor -->
    <text x="64" y="225">
      <tspan fill="#a45bea">.card </tspan>
      <tspan fill="rgba(255,255,255,0.5)">&#123;</tspan>
    </text>
    <!-- Cursor -->
    <rect x="112" y="215" width="1.5" height="11" fill="#4b95ea">
      <animate attributeName="opacity" values="1;0;1" dur="1.1s" repeatCount="indefinite"/>
    </rect>

  </svg>
</div>

<style>
  .gb-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gb-svg {
    width: 100%;
    height: 100%;
  }
</style>
