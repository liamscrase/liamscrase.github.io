---
import Layout from "../layouts/Layout.astro";
import FadeUpAnimation from "../components/FadeUpAnimation.astro";

const featuredProjects = [
  {
    title: "White label car dealership template",
    year: "2025",
    description:
      "Elevating the standards for car dealer websites in New Zealand with a modern website template and cutting-edge helpful AI features",
    href: "/dealer-websites",
    image: "/images/acme5/websites-home.webp",
    imageAlt: "White label website template for car dealerships",
    ariaLabel: "View Acme Website Template project details",
  },
  {
    title: "Avanti Finance App",
    year: "2025",
    description:
      "A convenient mobile and web app for customers to view where they're at with their loan repayments.",
    href: "/avanti",
    image: "/images/avanti-app/avanti-home.webp",
    imageAlt: "Avanti Finance App preview",
    ariaLabel: "View Avanti Finance App project details",
  },
  {
    title: "BuyerScore Website Redesign",
    year: "2025",
    description:
      "Redesigned the BuyerScore website to improve the user experience and improve brand awareness.",
    href: "/buyerscore",
    image: "/images/buyerscore/buyerscore-home.webp",
    imageAlt: "BuyerScore Website Redesign preview",
    ariaLabel: "View BuyerScore Website Redesign project details",
  },
];

const websiteBuilds = [
  {
    title: "The Serious Sandwich",
    year: "2025",
    description: "Food ordering website that is guaranteed to make you hungry",
    image: "https://picsum.photos/seed/sandwich/600/400",
    href: "#",
  },
  {
    title: "St. Nicholas Orthodox Church",
    year: "2025",
    description: "Elegant yet modern with integrated CMS",
    image: "https://picsum.photos/seed/church/600/400",
    href: "#",
  },
  {
    title: "Simply Stunning Studios Tekapo",
    year: "2025",
    description: "Lakeside holiday studios with seamless online booking",
    image: "https://picsum.photos/seed/studio/600/400",
    href: "#",
  },
];
---

<FadeUpAnimation />

<Layout>
  <section id="body-wrapper">
    <section id="banner">
      <div class="content">
        <div class="text">
          <h1>
            I design and build digital products that provide delightful
            experiences.
            <br /><span>(After my coffee, of course)</span>
          </h1>
        </div>
  
        <img
          class="banner-illustration"
          src="/images/liam-cartoon.svg"
          alt=""
          width="200"
          height="200"
        />

      </div>
    </section>
    <div id="main" class="content">
      <div id="case-studies">
        <div class="section-header">
          <h2>Featured Projects</h2>
          <p>Some of my favorite projects that I've worked on.</p>
        </div>
        <div class="project-list">
          {featuredProjects.map((project, index) => (
            <div class={`project-card fade-up${index % 2 === 1 ? " reverse" : ""}`}>
              <img class="project-image" src={project.image} alt={project.imageAlt} />
              <div class="text">
                <h3>{project.title}</h3>
                <span>{project.year}</span>
                <p>{project.description}</p>
                <a class="button grey" href={project.href} aria-label={project.ariaLabel}>
                  View project <i class="icon-arrow"></i>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div id="website-builds">
        <div class="section-header">
          <h2>Website builds</h2>
          <p>Websites designed, built, and launched for real clients.</p>
        </div>
        <div class="website-builds-grid">
          {websiteBuilds.map((site) => (
            <article class="website-builds-card">
              <img
                src={site.image}
                alt=""
                width="600"
                height="400"
                class="website-builds-card-image"
              />
              <div class="website-builds-card-body">
                <h3>{site.title}</h3>
                <span>{site.year}</span>
                <p>{site.description}</p>
                <a href={site.href} class="button grey">
                  Visit live site <i class="icon-arrow"></i>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
