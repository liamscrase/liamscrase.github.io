---
// GraphicDesign.astro — Figma canvas animation: cursor draws a card component
---

<div class="gd-wrap" aria-hidden="true">
  <svg class="gd-svg" viewBox="0 0 400 260" xmlns="http://www.w3.org/2000/svg" font-family="monospace">

    <!-- ── Figma chrome ── -->
    <!-- Toolbar -->
    <rect x="0" y="0" width="400" height="260" fill="#1e1e1e"/>
    <rect x="0" y="0" width="400" height="32" fill="#2c2c2c"/>

    <!-- Figma logo mark -->
    <rect x="10" y="8" width="16" height="16" rx="2" fill="#ff7262"/>
    <text x="18" y="20" text-anchor="middle" fill="white" font-size="9" font-weight="bold">F</text>

    <!-- Tool icons -->
    <g fill="rgba(255,255,255,0.35)" font-size="8" text-anchor="middle">
      <rect x="34" y="9" width="14" height="14" rx="2" fill="rgba(255,255,255,0.15)"/>
      <text x="41" y="19">V</text>
      <rect x="52" y="9" width="14" height="14" rx="2" fill="rgba(255,255,255,0.08)"/>
      <text x="59" y="19">F</text>
      <rect x="70" y="9" width="14" height="14" rx="2" fill="rgba(255,255,255,0.08)"/>
      <text x="77" y="19">R</text>
      <rect x="88" y="9" width="14" height="14" rx="2" fill="rgba(255,255,255,0.08)"/>
      <text x="95" y="19">T</text>
    </g>

    <!-- Share / Present buttons -->
    <rect x="290" y="8" width="50" height="16" rx="3" fill="#0d99ff"/>
    <text x="315" y="19" text-anchor="middle" fill="white" font-size="7">Share</text>
    <rect x="346" y="8" width="44" height="16" rx="3" fill="rgba(255,255,255,0.1)"/>
    <text x="368" y="19" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-size="7">Present</text>

    <!-- Left panel -->
    <rect x="0" y="32" width="56" height="228" fill="#252525"/>
    <text x="28" y="50" text-anchor="middle" fill="rgba(255,255,255,0.25)" font-size="7">Layers</text>
    <line x1="8" y1="56" x2="48" y2="56" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
    <!-- Layer items -->
    <g fill="rgba(255,255,255,0.2)" font-size="7">
      <rect x="8" y="62" width="6" height="6" rx="1" fill="rgba(255,255,255,0.15)"/>
      <text x="18" y="69">Card</text>
      <rect x="12" y="74" width="5" height="5" rx="1" fill="rgba(255,255,255,0.1)"/>
      <text x="20" y="80">Header</text>
      <rect x="12" y="85" width="5" height="5" rx="1" fill="rgba(255,255,255,0.1)"/>
      <text x="20" y="91">Body</text>
      <rect x="12" y="96" width="5" height="5" rx="1" fill="rgba(255,255,255,0.1)"/>
      <text x="20" y="102">Button</text>
    </g>

    <!-- Right panel -->
    <rect x="320" y="32" width="80" height="228" fill="#252525"/>
    <text x="360" y="50" text-anchor="middle" fill="rgba(255,255,255,0.25)" font-size="7">Design</text>
    <line x1="326" y1="56" x2="394" y2="56" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
    <g fill="rgba(255,255,255,0.2)" font-size="7">
      <text x="328" y="68">W</text><rect x="342" y="60" width="44" height="11" rx="2" fill="rgba(255,255,255,0.08)"/><text x="364" y="69" text-anchor="middle" fill="rgba(255,255,255,0.4)">240</text>
      <text x="328" y="82">H</text><rect x="342" y="74" width="44" height="11" rx="2" fill="rgba(255,255,255,0.08)"/><text x="364" y="83" text-anchor="middle" fill="rgba(255,255,255,0.4)">140</text>
      <text x="328" y="96">R</text><rect x="342" y="88" width="44" height="11" rx="2" fill="rgba(255,255,255,0.08)"/><text x="364" y="97" text-anchor="middle" fill="rgba(255,255,255,0.4)">8</text>
      <line x1="326" y1="106" x2="394" y2="106" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
      <text x="328" y="118">Fill</text>
      <rect x="342" y="110" width="12" height="11" rx="2" fill="#a45bea"/>
      <rect x="358" y="110" width="28" height="11" rx="2" fill="rgba(255,255,255,0.08)"/>
      <text x="372" y="119" text-anchor="middle" fill="rgba(255,255,255,0.4)">A45BEA</text>
    </g>

    <!-- Canvas area -->
    <rect x="56" y="32" width="264" height="228" fill="#1e1e1e"/>

    <!-- Dot grid -->
    <pattern id="dots" x="0" y="0" width="16" height="16" patternUnits="userSpaceOnUse">
      <circle cx="8" cy="8" r="0.6" fill="rgba(255,255,255,0.08)"/>
    </pattern>
    <rect x="56" y="32" width="264" height="228" fill="url(#dots)"/>

    <!-- ── The card being drawn ── -->

    <!-- Card outline appears (stroke-dasharray animation) -->
    <rect x="110" y="70" width="180" height="120" rx="8"
          fill="rgba(30,30,30,0.9)" stroke="#a45bea" stroke-width="1.5"
          stroke-dasharray="600" stroke-dashoffset="600">
      <animate attributeName="stroke-dashoffset" values="600;0" dur="1.2s" begin="0.3s" fill="freeze" calcMode="easeOut"/>
    </rect>

    <!-- Selection handles appear after card is drawn -->
    <g opacity="0">
      <animate attributeName="opacity" values="0;1" dur="0.2s" begin="1.5s" fill="freeze"/>
      <!-- Corner handles -->
      <rect x="106" y="66"  width="7" height="7" rx="1" fill="white" stroke="#0d99ff" stroke-width="1"/>
      <rect x="283" y="66"  width="7" height="7" rx="1" fill="white" stroke="#0d99ff" stroke-width="1"/>
      <rect x="106" y="183" width="7" height="7" rx="1" fill="white" stroke="#0d99ff" stroke-width="1"/>
      <rect x="283" y="183" width="7" height="7" rx="1" fill="white" stroke="#0d99ff" stroke-width="1"/>
      <!-- Mid handles -->
      <rect x="195" y="66"  width="7" height="7" rx="1" fill="white" stroke="#0d99ff" stroke-width="1"/>
      <rect x="195" y="183" width="7" height="7" rx="1" fill="white" stroke="#0d99ff" stroke-width="1"/>
      <rect x="106" y="125" width="7" height="7" rx="1" fill="white" stroke="#0d99ff" stroke-width="1"/>
      <rect x="283" y="125" width="7" height="7" rx="1" fill="white" stroke="#0d99ff" stroke-width="1"/>
      <!-- Selection border -->
      <rect x="106" y="66" width="190" height="130" rx="0" fill="none" stroke="#0d99ff" stroke-width="1" stroke-dasharray="4 2"/>
    </g>

    <!-- Card inner content fades in -->
    <g opacity="0">
      <animate attributeName="opacity" values="0;1" dur="0.4s" begin="1.8s" fill="freeze"/>
      <!-- Header bar -->
      <rect x="118" y="78" width="164" height="8" rx="2" fill="rgba(164,91,234,0.3)"/>
      <!-- Title text placeholder -->
      <rect x="118" y="94" width="120" height="7" rx="2" fill="rgba(255,255,255,0.25)"/>
      <!-- Body text lines -->
      <rect x="118" y="107" width="148" height="5" rx="1" fill="rgba(255,255,255,0.1)"/>
      <rect x="118" y="116" width="136" height="5" rx="1" fill="rgba(255,255,255,0.1)"/>
      <rect x="118" y="125" width="110" height="5" rx="1" fill="rgba(255,255,255,0.1)"/>
      <!-- Button -->
      <rect x="118" y="140" width="60" height="20" rx="4" fill="#a45bea"/>
      <rect x="118" y="140" width="60" height="20" rx="4" fill="rgba(255,255,255,0.0)"/>
      <text x="148" y="153" text-anchor="middle" fill="white" font-size="7">View more</text>
    </g>

    <!-- ── Cursor ── -->
    <!-- Cursor moves: start off-canvas → drag draw position → settle at card → move to button -->
    <g>
      <!-- Cursor arrow -->
      <polygon points="0,0 0,14 4,10 7,16 9,15 6,9 11,9" fill="white" stroke="#333" stroke-width="0.5">
        <!-- Move to draw start -->
        <animateTransform attributeName="transform" type="translate"
          values="220,180; 110,70; 110,70; 200,130; 148,148"
          keyTimes="0; 0.25; 0.55; 0.75; 1"
          dur="4s" repeatCount="indefinite" calcMode="spline"
          keySplines="0.4 0 0.2 1; 0.4 0 0.2 1; 0.4 0 0.2 1; 0.4 0 0.2 1"/>
      </polygon>
      <!-- Click dot — flashes at draw start and at button -->
      <circle cx="0" cy="0" r="5" fill="rgba(13,153,255,0.4)" stroke="none">
        <animateTransform attributeName="transform" type="translate"
          values="220,180; 110,70; 110,70; 200,130; 148,148"
          keyTimes="0; 0.25; 0.55; 0.75; 1"
          dur="4s" repeatCount="indefinite" calcMode="spline"
          keySplines="0.4 0 0.2 1; 0.4 0 0.2 1; 0.4 0 0.2 1; 0.4 0 0.2 1"/>
        <animate attributeName="opacity" values="0;0;1;0;0;1;0" keyTimes="0;0.24;0.25;0.3;0.74;0.75;0.8" dur="4s" repeatCount="indefinite"/>
        <animate attributeName="r" values="5;12;5" dur="0.4s" repeatCount="indefinite"/>
      </circle>
    </g>

  </svg>
</div>

<style>
  .gd-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gd-svg {
    width: 100%;
    height: 100%;
  }
</style>