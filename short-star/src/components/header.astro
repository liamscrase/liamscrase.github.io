---
const currentPath = Astro.url.pathname;
---

<nav>
  <div class="content">
    <a class="logo" href="/">Liam Scrase</a>
    <ul>
      <li><a href="/" class={currentPath === "/" ? "active" : ""}>Home</a></li>
      <li><a href="/contact" class={currentPath === "/contact" ? "active" : ""}>Contact</a></li>
    </ul>
  </div>
</nav>

<script>
  // @ts-nocheck
  document.addEventListener("DOMContentLoaded", () => {
    const nav = document.querySelector("nav");
    let ticking = false;
    let isScrolled = false;

    // ── SCROLLED STATE ────────────────────────────────
    window.addEventListener("scroll", () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const shouldBeScrolled = window.scrollY > 10;
          if (shouldBeScrolled !== isScrolled) {
            isScrolled = shouldBeScrolled;
            nav?.classList.toggle("scrolled", isScrolled);
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // ── THEME INVERSION ───────────────────────────────
    window.addEventListener('process:fullscreen', (e) => {
      nav?.classList.toggle('theme-light', e.detail.active)
    })
  });
</script>