---
import Layout from "../layouts/Layout.astro";
import FadeUpAnimation from "../components/FadeUpAnimation.astro";
import Ticker from "../components/Ticker.astro";
import ProcessFlow from "../components/ProcessFlow.astro";
import ProcessFlowVertical from "../components/ProcessFlowVertical.astro";

const tools = [
  { name: "Figma", src: "/images/logos/figma.svg" },
  { name: "Adobe CC", src: "/images/logos/adobe.svg" },
  { name: "Astro", src: "/images/logos/astro.svg" },
  { name: "Figma", src: "/images/logos/figma.svg" },
  { name: "Adobe CC", src: "/images/logos/adobe.svg" },
  { name: "Astro", src: "/images/logos/astro.svg" },
];
---

<link rel="stylesheet" href="/process-flow.css" />
<link rel="stylesheet" href="/process-flow-vertical.css" />
<FadeUpAnimation />
<Ticker />

<Layout>
  <Fragment slot="head">
    <link
      rel="preload"
      href="/images/dither-blue-horizontal.svg"
      as="image"
      media="(min-width: 1200px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="/images/dither-blue-large.svg"
      as="image"
      media="(min-width: 700px) and (max-width: 1199px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="/images/dither-blue.svg"
      as="image"
      media="(max-width: 699px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="/images/dither-green-horizontal.svg"
      as="image"
      media="(min-width: 1200px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="/images/dither-green-large.svg"
      as="image"
      media="(min-width: 700px) and (max-width: 1199px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="/images/dither-green.svg"
      as="image"
      media="(max-width: 699px)"
      fetchpriority="high"
    />
  </Fragment>
  <section id="body-wrapper">
    <div class="content flex column gap-large">
      <section id="banner">
        <div class="blurb">
          <img src="images/profile.jpg" alt="" />
          <div class="inner">
            <h1>Hi, I'm Liam 👋</h1>
            <p>
              UX/UI Designer & Front End Support with 4 years of experience.
              Currently working for Motorcentral Technologies — a leading tech
              company based in Christchurch, New Zealand.
            </p>
            <p>
              Experience in digital design and front end development, with a
              passion for creating user-friendly, accessible, and visually
              appealing digital experiences.
            </p>
          </div>
        </div>
      </section>
      <div class="flex column gap-large">
        <section id="projects">
          <div class="flex column gap-small">
            <div class="section-header fade-up">
              <span class="sub-header">UX/UI Design</span>
              <h2>Project Case Studies</h2>
              <p>
                Case studies of my best UX projects, showcasing innovation,
                design thinking, and problem-solving approaches.
              </p>
            </div>
            <section id="project-list">
              <div class="project-card panel-blue-pixel acme fade-up">
                <div class="text">
                  <h3>Acme Website Template</h3>
                  <span>2025</span>
                  <p>
                    Elevating the standards for car dealer websites in New
                    Zealand with a modern website template and cutting-edge
                    helpful AI features
                  </p>
                  <a
                    class="button blue"
                    href="/acme"
                    aria-label="View Acme Website Template project details"
                  >
                    View project <i class="icon-arrow"></i>
                  </a>
                </div>
                <div class="project-image-container">
                  <img
                    class="project-image"
                    src="/images/acme5/acme5_graphic.webp"
                    alt="Acme Cars website preview"
                  />
                </div>
                <picture>
                  <source
                    media="(min-width: 1200px)"
                    srcset="/images/dither-blue-horizontal.svg"
                  />
                  <source
                    media="(min-width: 700px)"
                    srcset="/images/dither-blue-large.svg"
                  />
                  <img
                    class="dither"
                    src="/images/dither-blue.svg"
                    alt="Blue dither"
                    fetchpriority="high"
                  />
                </picture>
              </div>

              <div class="project-card panel-green-pixel avanti fade-up">
                <div class="text">
                  <h3>Avanti Finance App</h3>
                  <span>2025</span>

                  <p>
                    A convenient mobile and web app for customers to view where
                    they’re at with their loan repayments.
                  </p>
                  <a
                    class="button green"
                    href="/avanti"
                    aria-label="View Avanti Finance App project details"
                  >
                    View project <i class="icon-arrow"></i>
                  </a>
                </div>
                <div class="project-image-container">
                  <img
                    class="project-image"
                    src="/images/avanti-app/avanti_graphic.webp"
                    alt="Avanti Finance App preview"
                  />
                </div>
                <picture>
                  <source
                    media="(min-width: 1200px)"
                    srcset="/images/dither-green-horizontal.svg"
                  />
                  <source
                    media="(min-width: 700px)"
                    srcset="/images/dither-green-large.svg"
                  />
                  <img
                    class="dither"
                    src="/images/dither-green.svg"
                    alt="Green dither"
                    fetchpriority="high"
                  />
                </picture>
              </div>
            </section>
          </div>
        </section>
        <section id="more-projects" class="flex column gap-small">
          <div class="section-header fade-up">
            <span class="sub-header">Design + Dev</span>
            <h2>Website Projects</h2>
            <p>
              Solo projects where I designed and built complete websites from
              concept to launch.
            </p>
          </div>

          <div class="mini-grid">
            <a
              class="mini-card panel-grey fade-up"
              href="https://theserioussandwich.nz/"
              aria-label="Open The Serious Sandwich website"
              target="_blank"
            >
              <h3>The Serious Sandwich</h3>

              <span class="year">2025</span>
              <p>Playful brand site with a tight, clear menu layout.</p>
              <div class="button grey">
                Visit website
                <i class="icon-open"></i>
              </div>
            </a>
            <a
              class="mini-card panel-grey fade-up"
              href="https://simplystunningstudiostekapo.nz/"
              aria-label="Open Simply Stunning Studios website"
              target="_blank"
            >
              <h3>Simply Stunning Studios</h3>

              <span class="year">2025</span>
              <p>
                Lake Tekapo accommodation site with streamlined booking flow.
              </p>
              <div class="button grey">
                Visit website
                <i class="icon-open"></i>
              </div>
            </a>
            <a
              class="mini-card panel-grey fade-up"
              href="https://terapacars.co.nz/"
              aria-label="Open Te Rapa Cars website"
              target="_blank"
            >
              <h3>Te Rapa Cars</h3>

              <span class="year">2026</span>
              <p>
                Modern used car dealership site showcasing inventory with
                advanced search.
              </p>
              <div class="button grey">
                Visit website
                <i class="icon-open"></i>
              </div>
            </a>
          </div>
        </section>
      </div>
    </div>
    <section class="process-section">
      <ProcessFlowVertical />
    </section>
  </section>
</Layout>

<script is:inline>
  (() => {
    function scale(frame) {
      const canvas = frame.querySelector('.canvas');
      if (!canvas) return;
      const s = Math.min(frame.clientWidth / 400, frame.clientHeight / 225);
      canvas.style.transform = `scale(${s})`;
      canvas.style.left = `${(frame.clientWidth  - 400 * s) / 2}px`;
      canvas.style.top  = `${(frame.clientHeight - 225 * s) / 2}px`;
    }
    const ro = new ResizeObserver(entries => entries.forEach(e => scale(e.target)));
    document.querySelectorAll('.scale-target').forEach(f => { scale(f); ro.observe(f); });
  })();
</script>