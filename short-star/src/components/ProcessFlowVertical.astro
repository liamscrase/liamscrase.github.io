<link rel="stylesheet" href="process-flow-v2.css">

<div id="process-v2-container">
  <div class="pv2-sticky-wrap">
    <section id="process-v2">
      <div class="pv2-inner">

        <div class="pv2-header">
          <h2>How I work</h2>
          <p>A structured process from first principles to shipped product — research-led, design-driven, and built to last.</p>
        </div>

        <div class="pv2-body">
          <div class="pv2-cards" id="pv2-cards"></div>

          <div class="pv2-progress">
            <div class="pv2-progress-track">
              <div class="pv2-progress-bar" id="pv2-bar"></div>
            </div>
            <div class="pv2-step-nodes" id="pv2-nodes"></div>
          </div>
        </div>

      </div>
    </section>
  </div>
</div>

<script type="module">
import { animate } from "https://cdn.jsdelivr.net/npm/motion@11/+esm"

// ── DATA ─────────────────────────────────────────────
const STEPS = [
  { number: "01", phase: "Research",  color: "#4b95ea",
    description: "Understanding the problem space. Stakeholder interviews, competitor analysis, and defining user needs before a single frame is drawn.",
    tools: ["User Interviews", "Competitor Analysis", "User Flows"] },
  { number: "02", phase: "Wireframe", color: "#7b7bea",
    description: "Rough structure before polish. Low-fidelity layouts that map out hierarchy, flow, and interaction patterns quickly.",
    tools: ["Figma", "Whiteboarding"] },
  { number: "03", phase: "Design",    color: "#a45bea",
    description: "High-fidelity visuals, component libraries, and interactive prototypes. Every detail considered — spacing, type, colour, motion.",
    tools: ["Figma", "Adobe CC"] },
  { number: "04", phase: "Build",     color: "#3cd870",
    description: "Translating designs into production-ready code. Clean, semantic HTML and SCSS with a focus on performance and accessibility.",
    tools: ["Astro", "HTML", "SCSS", "TypeScript"] },
  { number: "05", phase: "Ship",      color: "#3cd8b0",
    description: "Tested, optimised, and launched. Handoff documentation, performance checks, and making sure everything holds up in the real world.",
    tools: ["Git", "Performance Audit"] },
]
const TOTAL = STEPS.length

// ── ELEMENTS ─────────────────────────────────────────
const stickyWrap = document.querySelector('.pv2-sticky-wrap')
const cardsWrap  = document.getElementById('pv2-cards')
const bar        = document.getElementById('pv2-bar')
const nodesWrap  = document.getElementById('pv2-nodes')
const container  = document.getElementById('process-v2-container')

// ── BUILD DOM ─────────────────────────────────────────
const cardEls  = []
const nodeEls  = []

STEPS.forEach((step, i) => {
  // Node
  const node = document.createElement('button')
  node.className = 'pv2-node'
  node.style.setProperty('--step-color', step.color)
  node.setAttribute('aria-label', `View ${step.phase} step`)
  node.innerHTML = `<span class="pv2-node-number">${step.number}</span>`
  nodesWrap.appendChild(node)
  nodeEls.push(node)

  // Card — each one is sticky at the same top so they stack
  const card = document.createElement('div')
  card.className = 'pv2-card'
  card.style.setProperty('--step-color', step.color)
  card.style.zIndex = i + 1
  card.innerHTML = `
    <div class="pv2-card-content">
      <div class="pv2-card-text">
        <div class="pv2-card-header">
          <span class="pv2-card-number">${step.number}</span>
          <h3>${step.phase}</h3>
        </div>
        <p>${step.description}</p>
        <div class="pv2-tools">
          ${step.tools.map(t => `<span class="pv2-tool">${t}</span>`).join('')}
        </div>
      </div>
      <div class="pv2-card-image"></div>
    </div>
  `
  cardsWrap.appendChild(card)
  cardEls.push(card)
})

// ── STATE ─────────────────────────────────────────────
let current = 0

// ── GOTO ──────────────────────────────────────────────
function goTo(index) {
  if (index === current && index !== 0) return
  current = index

  nodeEls.forEach((node, i) => {
    node.classList.toggle('active', i === index)
    node.classList.toggle('past',   i < index)
  })

  bar.style.setProperty('--step-color', STEPS[index].color)
}

// Node clicks — scroll to that card's position
nodeEls.forEach((node, i) => {
  node.addEventListener('click', () => {
    const scrollRange = container.offsetHeight - window.innerHeight
    const targetY = container.offsetTop + (i / (TOTAL - 1)) * scrollRange
    window.scrollTo({ top: targetY, behavior: 'smooth' })
  })
})

// ── HELPERS ───────────────────────────────────────────
function clamp(v, lo, hi) { return Math.min(hi, Math.max(lo, v)) }
function easeInOut(t) {
  return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2
}

// ── SCROLL ────────────────────────────────────────────
let sequenceDone = false
let lastScrollY  = window.scrollY

function onScroll() {
  const scrollY       = window.scrollY
  const scrollingDown = scrollY >= lastScrollY
  lastScrollY = scrollY

  if (sequenceDone && !scrollingDown) return

  const rect        = container.getBoundingClientRect()
  const scrolled    = -rect.top
  const scrollRange = container.offsetHeight - window.innerHeight
  if (scrolled < 0 || scrolled > scrollRange) return

  const p = clamp(scrolled / scrollRange, 0, 1)

  // Progress bar height
  bar.style.height = `${p * 100}%`
  bar.classList.toggle('live', p > 0.01 && p < 0.99)

  // Which card is active
  const nodePositions = STEPS.map((_, i) => i / (TOTAL - 1))
  let targetIndex = 0
  for (let i = 0; i < TOTAL; i++) {
    if (p >= nodePositions[i]) targetIndex = i
  }
  goTo(targetIndex)

  // Card stacking — each card slides up from below as its turn comes
  STEPS.forEach((_, i) => {
    const cardStart = i / TOTAL
    const cardEnd   = (i + 1) / TOTAL
    const cardP     = clamp((p - cardStart) / (cardEnd - cardStart), 0, 1)
    const eased     = easeInOut(cardP)

    if (i === 0) {
      cardEls[i].style.transform = `translateY(0)`
      cardEls[i].style.opacity   = '1'
    } else {
      cardEls[i].style.transform = `translateY(${(1 - eased) * 100}%)`
      cardEls[i].style.opacity   = String(clamp(eased * 3, 0, 1))
    }

    // Darken this card as the next one slides over it
    const nextStart = (i + 1) / TOTAL
    const nextEnd   = (i + 2) / TOTAL
    const coverP    = clamp((p - nextStart) / (nextEnd - nextStart), 0, 1)
    cardEls[i].style.setProperty('--cover-dark', String(easeInOut(coverP) * 0.45))
  })

  if (p >= 1 && !sequenceDone) {
    sequenceDone = true
    stickyWrap.style.position = 'relative'
  }
}

window.addEventListener('scroll', onScroll, { passive: true })

// ── INIT ─────────────────────────────────────────────
function setVh() {
  document.documentElement.style.setProperty('--vh', `${window.innerHeight}px`)
}
setVh()
container.style.height = `${window.innerHeight * 6}px`

let lastVh = window.innerHeight
let resizeTimer
window.addEventListener('resize', () => {
  const delta = Math.abs(window.innerHeight - lastVh)
  if (delta < 100) return
  lastVh = window.innerHeight
  setVh()
  container.style.height = `${window.innerHeight * 6}px`
  clearTimeout(resizeTimer)
  resizeTimer = setTimeout(() => { onScroll() }, 150)
})

goTo(0)
</script>