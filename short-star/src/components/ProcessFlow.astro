---
const steps = [
  {
    number: "01",
    phase: "Research",
    description:
      "Understanding the problem space. Stakeholder interviews, competitor analysis, and defining user needs before a single frame is drawn.",
    tools: ["User Interviews", "Competitor Analysis", "User Flows"],
    color: "#4b95ea",
  },
  {
    number: "02",
    phase: "Wireframe",
    description:
      "Rough structure before polish. Low-fidelity layouts that map out hierarchy, flow, and interaction patterns quickly.",
    tools: ["Figma", "Whiteboarding"],
    color: "#7b7bea",
  },
  {
    number: "03",
    phase: "Design",
    description:
      "High-fidelity visuals, component libraries, and interactive prototypes. Every detail considered — spacing, type, colour, motion.",
    tools: ["Figma", "Adobe CC"],
    color: "#a45bea",
  },
  {
    number: "04",
    phase: "Build",
    description:
      "Translating designs into production-ready code. Clean, semantic HTML and SCSS with a focus on performance and accessibility.",
    tools: ["Astro", "HTML", "SCSS", "TypeScript"],
    color: "#3cd870",
  },
  {
    number: "05",
    phase: "Ship",
    description:
      "Tested, optimised, and launched. Handoff documentation, performance checks, and making sure everything holds up in the real world.",
    tools: ["Git", "Performance Audit"],
    color: "#3cd8b0",
  },
];
---

<link rel="stylesheet" href="/process-flow.css" />

<div id="process-scroll-container" class="theme-light">
  <section id="process">
    <div class="process-sticky">
      <div class="process-inner">
        <div class="section-header fade-up">
          <span class="sub-header">My Process</span>
          <h2>From design to development</h2>
          <p>
            Every project follows the same north star — understand the problem
            deeply, design it carefully, then build it well.
          </p>
        </div>

        <!-- Step nodes -->
        <div class="process-steps fade-up">
          {
            steps.map((step, i) => (
              <div class="process-step-wrapper">
                <button
                  class="process-step"
                  data-index={i}
                  data-color={step.color}
                  aria-label={`View ${step.phase} step`}
                >
                  <div class="process-node">
                    <span class="process-number">{step.number}</span>
                  </div>
                  <span class="process-label">{step.phase}</span>
                </button>
                {i < steps.length - 1 && (
                  <div class="process-connector" data-index={i} />
                )}
              </div>
            ))
          }
        </div>

        <!-- Detail cards -->
        <div class="process-cards fade-up">
          {
            steps.map((step, i) => (
              <div
                class="process-card"
                data-index={i}
                style={`--step-color: ${step.color}`}
              >
                <div class="process-card-header">
                  <span class="process-card-number">{step.number}</span>
                  <h3>{step.phase}</h3>
                </div>
                <p>{step.description}</p>
                <div class="process-tools">
                  {step.tools.map((tool) => (
                    <span class="process-tool">{tool}</span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>

        <!-- Nav -->
        <div class="process-nav fade-up">
          <button
            class="process-nav-btn"
            id="process-prev"
            aria-label="Previous step"
          >
            ← Prev
          </button>
          <button
            class="process-nav-btn"
            id="process-next"
            aria-label="Next step"
          >
            Next →
          </button>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  import { animate } from "motion";

  const steps = document.querySelectorAll<HTMLButtonElement>(".process-step");
  const cards = document.querySelectorAll<HTMLElement>(".process-card");
  const connectors =
    document.querySelectorAll<HTMLElement>(".process-connector");
  const prevBtn = document.getElementById("process-prev") as HTMLButtonElement;
  const nextBtn = document.getElementById("process-next") as HTMLButtonElement;
  const container = document.getElementById(
    "process-scroll-container",
  ) as HTMLElement;

  let current = 0;
  const total = steps.length;

  function animateCardIn(card: HTMLElement) {
    animate(
      card as Element,
      { opacity: [0, 1], translateY: [10, 0] },
      { duration: 0.3, ease: "easeOut" },
    );
  }

  function animateNodeActive(node: HTMLElement) {
    animate(
      node as Element,
      { scale: [0.85, 1] },
      { duration: 0.25, ease: [0.34, 1.56, 0.64, 1] },
    );
  }

  function goTo(index: number) {
    if (index < 0 || index >= total) return;

    steps.forEach((step, i) => {
      step.classList.toggle("active", i === index);
      step.classList.toggle("past", i < index);
      if (i === index) {
        step.style.setProperty("--step-color", step.dataset.color ?? "");
        animateNodeActive(step.querySelector(".process-node") as HTMLElement);
      }
    });

    connectors.forEach((c, i) => c.classList.toggle("past", i < index));

    cards.forEach((card, i) => {
      card.classList.toggle("active", i === index);
      if (i === index) animateCardIn(card);
    });

    prevBtn.disabled = index === 0;
    nextBtn.disabled = index === total - 1;
    current = index;
  }

  function initScrollDriven() {
    window.addEventListener(
      "scroll",
      () => {
        const rect = container.getBoundingClientRect();
        const scrolled = -rect.top;
        const scrollRange = container.offsetHeight - window.innerHeight;
        if (scrolled < 0 || scrolled > scrollRange) return;
        const targetIndex = Math.min(
          total - 1,
          Math.floor((scrolled / scrollRange) * total),
        );
        if (targetIndex !== current) goTo(targetIndex);
      },
      { passive: true },
    );
  }

  // Init
  goTo(0);

  steps.forEach((step, i) => step.addEventListener("click", () => goTo(i)));
  prevBtn.addEventListener("click", () => goTo(current - 1));
  nextBtn.addEventListener("click", () => goTo(current + 1));

  // Scroll-driven only on desktop
  const mq = window.matchMedia("(min-width: 1200px)");
  if (mq.matches) initScrollDriven();
  mq.addEventListener("change", (e) => {
    if (e.matches) initScrollDriven();
  });
</script>
