---
// GraphicWireframe.astro — Browser wireframe skeleton
---

<div class="frame scale-target">
  <div class="canvas">

    <div class="browser">

      <div class="titlebar">
        <div class="dots">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
        </div>
        <div class="urlbar"></div>
      </div>

      <div class="navbar">
        <div class="bar bar--logo"></div>
        <div class="nav-links">
          <div class="bar bar--nav"></div>
          <div class="bar bar--nav"></div>
          <div class="bar bar--nav"></div>
        </div>
        <div class="bar bar--cta"></div>
      </div>

      <div class="hero">
        <div class="hero-text">
          <div class="bar bar--h1"></div>
          <div class="bar bar--h1 bar--h1-sm"></div>
          <div class="bar bar--body"></div>
          <div class="bar bar--body bar--body-sm"></div>
          <div class="hero-buttons">
            <div class="btn btn--filled"></div>
            <div class="btn btn--outline"></div>
          </div>
        </div>
        <div class="hero-img">
          <div class="x-mark"></div>
        </div>
      </div>

      <div class="cards">
        <div class="card">
          <div class="bar bar--card-title"></div>
          <div class="bar bar--card-body"></div>
          <div class="bar bar--card-body bar--card-body-sm"></div>
          <div class="btn btn--card"></div>
        </div>
        <div class="card">
          <div class="bar bar--card-title"></div>
          <div class="bar bar--card-body"></div>
          <div class="bar bar--card-body bar--card-body-sm"></div>
          <div class="btn btn--card"></div>
        </div>
        <div class="card">
          <div class="bar bar--card-title"></div>
          <div class="bar bar--card-body"></div>
          <div class="bar bar--card-body bar--card-body-sm"></div>
          <div class="btn btn--card"></div>
        </div>
      </div>

    </div>

  </div>
</div>

<style>
  .frame {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .canvas {
    position: absolute;
    top: 0; left: 0;
    width: 400px;
    height: 225px;
    transform-origin: top left;
  }

  /* ── Browser shell ── */
  .browser {
    width: 400px;
    height: 225px;
    background: #0d0d0d;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  /* ── Title bar ── */
  .titlebar {
    position: relative;
    height: 26px;
    background: #161616;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 10px;
    flex-shrink: 0;
  }

  .dots { display: flex; gap: 4px; }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
        background: rgba(255,255,255,0.15);
  }

  .urlbar {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 38%;
    height: 12px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 3px;
    pointer-events: none;
  }

  /* ── Nav bar ── */
  .navbar {
    height: 26px;
    background: #111;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 12px;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    gap: 8px;
    flex: 1;
  }

  /* ── Generic bars ── */
  .bar { border-radius: 2px; flex-shrink: 0; }

  .bar--logo   { width: 34px; height: 10px; background: rgba(255,255,255,0.18); }
  .bar--nav    { width: 26px; height: 7px;  background: rgba(255,255,255,0.07); }
  .bar--cta    { width: 32px; height: 11px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); }
  .bar--h1     { width: 62%;  height: 11px; background: rgba(255,255,255,0.2); margin-bottom: 5px; }
  .bar--h1-sm  { width: 40%; }
  .bar--body   { width: 78%;  height: 7px;  background: rgba(255,255,255,0.07); margin-bottom: 4px; }
  .bar--body-sm { width: 52%; }
  .bar--card-title { width: 52%; height: 7px; background: rgba(255,255,255,0.16); margin-bottom: 4px; }
  .bar--card-body  { width: 82%; height: 6px; background: rgba(255,255,255,0.06); margin-bottom: 3px; }
  .bar--card-body-sm { width: 58%; }

  /* ── Buttons ── */
  .btn {
    border-radius: 3px;
    flex-shrink: 0;
  }

  .btn--filled  { width: 46px; height: 13px; background: rgba(255,255,255,0.11); border: 1px solid rgba(255,255,255,0.18); }
  .btn--outline { width: 40px; height: 13px; background: transparent; border: 1px solid rgba(255,255,255,0.1); }
  .btn--card    { width: 32px; height: 11px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); margin-top: 6px; }

  /* ── Hero ── */
  .hero {
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
  }

  .hero-text {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .hero-buttons {
    display: flex;
    gap: 6px;
    margin-top: 8px;
  }

  .hero-img {
    width: 28%;
    height: 80%;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }

  .x-mark {
    position: absolute;
    inset: 0;
  }

  .x-mark::before,
  .x-mark::after {
    content: '';
    position: absolute;
    width: 141%;
    height: 1px;
    background: rgba(255,255,255,0.06);
    top: 50%;
    left: 50%;
    transform-origin: center;
  }

  .x-mark::before { transform: translate(-50%, -50%) rotate(33deg); }
  .x-mark::after  { transform: translate(-50%, -50%) rotate(-33deg); }

  /* ── Cards row ── */
  .cards {
    display: flex;
    gap: 7px;
    padding: 0 12px 10px;
    flex-shrink: 0;
  }

  .card {
    flex: 1;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    padding: 7px;
    display: flex;
    flex-direction: column;
  }
</style>

<script is:inline>
  (() => {
    function scale(frame) {
      const canvas = frame.querySelector('.canvas');
      if (!canvas) return;
      const s = Math.min(frame.clientWidth / 400, frame.clientHeight / 225);
      canvas.style.transform = `scale(${s})`;
      canvas.style.left = `${(frame.clientWidth  - 400 * s) / 2}px`;
      canvas.style.top  = `${(frame.clientHeight - 225 * s) / 2}px`;
    }
    const ro = new ResizeObserver(entries => entries.forEach(e => scale(e.target)));
    document.querySelectorAll('.scale-target').forEach(f => { scale(f); ro.observe(f); });
  })();
</script>