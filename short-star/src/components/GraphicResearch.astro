---
// GraphicResearch.astro — Affinity board, wireframe aesthetic
---

<div class="frame scale-target">
  <div class="canvas">

    <div class="browser">

      <div class="titlebar">
        <div class="dots">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
        </div>
        <div class="filename">research.fig</div>
      </div>

      <div class="board-body">

        <!-- Pain Points -->
        <div class="cluster">
          <div class="cluster-label">Pain Points</div>
          <div class="notes">
            <div class="note">Can't find settings</div>
            <div class="note">Slow load times</div>
            <div class="note">Too many steps</div>
            <div class="note">No dark mode</div>
          </div>
        </div>

        <!-- Goals -->
        <div class="cluster">
          <div class="cluster-label">Goals</div>
          <div class="notes">
            <div class="note">Save time on tasks</div>
            <div class="note">Track progress</div>
            <div class="note">Share with team</div>
          </div>
        </div>

        <!-- Behaviours -->
        <div class="cluster">
          <div class="cluster-label">Behaviours</div>
          <div class="notes">
            <div class="note">Uses mobile first</div>
            <div class="note">Skips onboarding</div>
            <div class="note">Relies on search</div>
            <div class="note">Power user shortcuts</div>
          </div>
        </div>

      </div><!-- board-body -->
    </div><!-- browser -->

  </div>
</div>

<style>
  .frame {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .canvas {
    position: absolute;
    top: 0; left: 0;
    width: 400px;
    height: 225px;
    transform-origin: top left;
    box-sizing: border-box;
  }

  /* ── Browser shell ── */
  .browser {
    width: 400px;
    height: 225px;
    background: #0d0d0d;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 16px 16px;
  }

  /* ── Title bar ── */
  .titlebar {
    position: relative;
    height: 26px;
    background: #161616;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 10px;
    flex-shrink: 0;
    background-image: none;
  }

  .dots { display: flex; gap: 4px; }

  .dot { width: 7px; height: 7px; border-radius: 50%;   background: rgba(255,255,255,0.15);
  }
  .filename {
    position: absolute;
    left: 0; right: 0; text-align: center; pointer-events: none;
    font-family: "Chivo Mono", monospace;
    font-size: 7px;
    color: rgba(255,255,255,0.2);
  }

  /* ── Body ── */
  .board-body {
    flex: 1;
    min-height: 0;
    display: flex;
    gap: 8px;
    padding: 10px 12px;
  }

  /* ── Cluster ── */
  .cluster {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .cluster-label {
    font-family: "Chivo Mono", monospace;
    font-size: 6px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    padding-bottom: 5px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  /* ── Notes ── */
  .notes {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .note {
    padding: 4px 7px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 2px;
    background: #161616;
    font-family: "Chivo Mono", monospace;
    font-size: 6.5px;
    color: rgba(255,255,255,0.35);
    white-space: nowrap;
    line-height: 1;
  }
</style>