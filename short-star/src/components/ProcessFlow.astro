<link rel="stylesheet" href="process-flow.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/css/splide-core.min.css">

<div id="process-scroll-container">
  <div class="process-sticky-wrap theme-light">
    <section id="process">
      <div class="process-inner">

        <div class="process-steps-wrap">
          <div class="process-steps" id="steps-row">
            <div class="process-progress-track">
              <div class="process-progress-bar" id="prog-bar">
                <div class="process-progress-tip"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="process-cards-outer">
          <div id="process-splide" class="splide">
            <div class="splide__track">
              <ul class="splide__list" id="cards-list"></ul>
            </div>
          </div>
        </div>

      </div>
    </section>
  </div>
</div>

<script type="module">
import { animate } from "https://cdn.jsdelivr.net/npm/motion@11/+esm"
import Splide from "https://cdn.jsdelivr.net/npm/@splidejs/splide@4/+esm"

// ── DATA ─────────────────────────────────────────────
const STEPS = [
  { number: "01", phase: "Research",  color: "#4b95ea",
    description: "Understanding the problem space. Stakeholder interviews, competitor analysis, and defining user needs before a single frame is drawn.",
    tools: ["User Interviews", "Competitor Analysis", "User Flows"] },
  { number: "02", phase: "Wireframe", color: "#7b7bea",
    description: "Rough structure before polish. Low-fidelity layouts that map out hierarchy, flow, and interaction patterns quickly.",
    tools: ["Figma", "Whiteboarding"] },
  { number: "03", phase: "Design",    color: "#a45bea",
    description: "High-fidelity visuals, component libraries, and interactive prototypes. Every detail considered — spacing, type, colour, motion.",
    tools: ["Figma", "Adobe CC"] },
  { number: "04", phase: "Build",     color: "#3cd870",
    description: "Translating designs into production-ready code. Clean, semantic HTML and SCSS with a focus on performance and accessibility.",
    tools: ["Astro", "HTML", "SCSS", "TypeScript"] },
  { number: "05", phase: "Ship",      color: "#3cd8b0",
    description: "Tested, optimised, and launched. Handoff documentation, performance checks, and making sure everything holds up in the real world.",
    tools: ["Git", "Performance Audit"] },
]
const TOTAL = STEPS.length

// ── ELEMENTS ─────────────────────────────────────────
const stickyWrap = document.querySelector('.process-sticky-wrap')
const stepsRow   = document.getElementById('steps-row')
const cardsList  = document.getElementById('cards-list')
const bar        = document.getElementById('prog-bar')
const container  = document.getElementById('process-scroll-container')

// ── BUILD DOM ─────────────────────────────────────────
const stepBtns = []
const progressTrack = stepsRow.querySelector('.process-progress-track')

STEPS.forEach((step, i) => {
  // Step node buttons
  const btn = document.createElement('button')
  btn.className = 'process-step'
  btn.style.setProperty('--step-color', step.color)
  btn.setAttribute('aria-label', `View ${step.phase} step`)
  btn.innerHTML = `
    <div class="process-node"><span class="process-number">${step.number}</span></div>
    <span class="process-label">${step.phase}</span>
  `
  stepsRow.insertBefore(btn, progressTrack)
  stepBtns.push(btn)

  // Splide slides
  const li = document.createElement('li')
  li.className = 'splide__slide process-card'
  li.style.setProperty('--step-color', step.color)
  li.innerHTML = `
    <div class="process-card-content">
      <div class="process-card-text">
        <div class="process-card-header">
          <h3>${step.phase}</h3>
        </div>
        <p>${step.description}</p>
        <div class="process-tools">
          ${step.tools.map(t => `<span class="process-tool">${t}</span>`).join('')}
        </div>
      </div>
      <div class="process-card-image"></div>
    </div>
  `
  cardsList.appendChild(li)
})

// ── SPLIDE ────────────────────────────────────────────
const splide = new Splide('#process-splide', {
  type:        'slide',
  perPage:     1,
  perMove:     1,
  gap:         '16px',
  arrows:      false,
  pagination:  false,
  drag:        false,
  touch:       false,
  speed:       600,
  easing:      'cubic-bezier(0.16, 1, 0.3, 1)',
})

splide.on('move', (newIndex) => {
  goTo(newIndex)
})

splide.mount()

// ── STATE ─────────────────────────────────────────────
let current = 0
let currentExpand = 0
let sequenceDone = false

// ── GOTO ──────────────────────────────────────────────
function goTo(index) {
  if (index < 0 || index >= TOTAL) return
  current = index

  stepBtns.forEach((btn, i) => {
    btn.classList.toggle('active', i === index)
    btn.classList.toggle('past',   i < index)
    if (i === index) {
      animate(
        btn.querySelector('.process-node'),
        { scale: [0.88, 1] },
        { duration: 0.45, ease: [0.16, 1, 0.3, 1] }
      )
    }
  })

  if (splide.index !== index) splide.go(index)

  bar.style.setProperty('--step-color', STEPS[index].color)
}

// Step node clicks
stepBtns.forEach((btn, i) => btn.addEventListener('click', () => {
  goTo(i)
}))

// ── EXPAND ────────────────────────────────────────────
const EXPAND_END   = 0.15
const SHRINK_START = 0.85

function clamp(v, lo, hi) { return Math.min(hi, Math.max(lo, v)) }

function easeInOut(t) {
  return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2
}

function setExpand(value) {
  currentExpand = value
  const isNarrow = window.innerWidth < 1200
  const vMax = isNarrow ? window.innerHeight * 0.10 : window.innerHeight * 0.22
  const hMax = isNarrow ? 0 : window.innerWidth * 0.09
  const vInset = ((1 - value) * vMax).toFixed(1)
  const hInset = ((1 - value) * hMax).toFixed(1)
  const radius = ((1 - value) * 18).toFixed(2)
  const shadow = (0.5 * (1 - value)).toFixed(3)

  stickyWrap.style.clipPath  = `inset(${vInset}px ${hInset}px round ${radius}px)`
  stickyWrap.style.boxShadow = `0 24px 80px rgba(0,0,0,${shadow})`

  window.dispatchEvent(new CustomEvent('process:fullscreen', { detail: { active: value === 1 } }))
}

// ── SWIPE / DRAG TO SCROLL ────────────────────────────
let pointerStartX = 0
let pointerStartScrollY = 0
let isDragging = false

function onPointerStart(clientX) {
  pointerStartX = clientX
  pointerStartScrollY = window.scrollY
  isDragging = true
}

function onPointerMove(clientX) {
  if (!isDragging) return
  const dx = pointerStartX - clientX
  const scrollRange = container.offsetHeight - window.innerHeight
  const scrollPerSlide = scrollRange / (TOTAL - 1)
  window.scrollTo({
    top: pointerStartScrollY + (dx / window.innerWidth) * scrollPerSlide * 2,
    behavior: 'instant'
  })
}

function onPointerEnd() {
  isDragging = false
}

// Touch
let touchStartY = 0
container.addEventListener('touchstart', (e) => {
  touchStartY = e.touches[0].clientY
  onPointerStart(e.touches[0].clientX)
}, { passive: true })

container.addEventListener('touchmove', (e) => {
  const dy = touchStartY - e.touches[0].clientY
  const dx = pointerStartX - e.touches[0].clientX
  // Only hijack if swipe is more horizontal than vertical
  if (Math.abs(dx) <= Math.abs(dy)) { isDragging = false; return }
  onPointerMove(e.touches[0].clientX)
}, { passive: true })

container.addEventListener('touchend', onPointerEnd, { passive: true })

// Mouse
container.addEventListener('mousedown', (e) => {
  e.preventDefault()
  onPointerStart(e.clientX)
  container.style.cursor = 'grabbing'
  document.body.style.userSelect = 'none'
})

window.addEventListener('mousemove', (e) => {
  if (!isDragging) return
  onPointerMove(e.clientX)
})

window.addEventListener('mouseup', () => {
  onPointerEnd()
  container.style.cursor = ''
  document.body.style.userSelect = ''
})

// ── SCROLL ────────────────────────────────────────────
let ignoreScroll = false
let lastScrollY = window.scrollY

function onScroll() {
  if (ignoreScroll) return

  const scrollY = window.scrollY
  const scrollingDown = scrollY >= lastScrollY
  lastScrollY = scrollY

  if (sequenceDone && !scrollingDown) return

  const rect        = container.getBoundingClientRect()
  const scrolled    = -rect.top
  const scrollRange = container.offsetHeight - window.innerHeight
  if (scrolled < 0 || scrolled > scrollRange) return

  const p = clamp(scrolled / scrollRange, 0, 1)

  let expand
  if (p < EXPAND_END) {
    expand = easeInOut(p / EXPAND_END)
  } else if (p > SHRINK_START) {
    expand = easeInOut(1 - (p - SHRINK_START) / (1 - SHRINK_START))
  } else {
    expand = 1
  }
  setExpand(expand)

  const innerP = clamp((p - EXPAND_END) / (SHRINK_START - EXPAND_END), 0, 1)
  bar.style.width = `${innerP * 100}%`
  bar.classList.toggle('live', innerP > 0.01 && innerP < 0.99)

  const nodePositions = STEPS.map((_, i) => i / (TOTAL - 1))
  let targetIndex = 0
  for (let i = 0; i < TOTAL; i++) {
    if (innerP >= nodePositions[i]) targetIndex = i
  }
  if (targetIndex !== current) goTo(targetIndex)

  if (p >= 1 && !sequenceDone) {
    sequenceDone = true
    stickyWrap.style.position = 'relative'
  }
}

window.addEventListener('scroll', onScroll, { passive: true })

// ── RESIZE ────────────────────────────────────────────
let resizeTimer
let lastVh = window.innerHeight

window.addEventListener('resize', () => {
  const delta = Math.abs(window.innerHeight - lastVh)
  if (delta < 100) return
  lastVh = window.innerHeight
  setVh()
  container.style.height = `${window.innerHeight * 6}px`
  setExpand(currentExpand)
  splide.refresh()
  clearTimeout(resizeTimer)
  resizeTimer = setTimeout(() => { onScroll() }, 150)
})

// ── INIT ─────────────────────────────────────────────
function setVh() {
  document.documentElement.style.setProperty('--vh', `${window.innerHeight}px`)
}
setVh()
container.style.height = `${window.innerHeight * 6}px`

setExpand(0)
goTo(0)
</script>