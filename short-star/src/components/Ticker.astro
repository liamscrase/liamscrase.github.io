  { name: "Astro", src: "/images/logos/astro.svg" },
];
---

<script>
  import { animate } from "motion";

  const track = document.getElementById("ticker-track") as HTMLElement;

  const player = animate(
    track,
    { x: ["0%", "-50%"] },
    {
      duration: 25,
      repeat: Infinity,
      ease: "linear",
    }
  );

  track.addEventListener("mouseenter", () => player.pause());
  track.addEventListener("mouseleave", () => player.play());
</script>